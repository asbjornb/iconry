{
  "name": "iconry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --r2=ASSETS_BUCKET",
    "mcp:build": "tsc -p mcp/tsconfig.json",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=iconry"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250310.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "wrangler": "^4.0.0"
  }
}
